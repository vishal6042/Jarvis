# Copy to .env and adjust. .env is gitignored. All vars have dev defaults in each service.

# --- Database (single jarvis DB; each service uses its own schema) ---
JARVIS_DB_URL=jdbc:postgresql://localhost:5432/jarvis
DB_USER=jarvis
DB_PASSWORD=jarvis

# --- Security ---
# Shared HS256 secret across all services (>= 32 bytes). Set a real one.
JARVIS_JWT_SECRET=change-me-in-env-at-least-32-bytes-long!!
# Shared service-to-service key for /internal/** endpoints.
JARVIS_INTERNAL_KEY=change-me-internal-key

# --- AI inference (local Ollama, ₹0) ---
JARVIS_PROFILE=local
OLLAMA_BASE_URL=http://localhost:11434
JARVIS_PARSER_MODEL=qwen3.5:9b
JARVIS_AGENT_MODEL=qwen3.5:27b

# --- Service discovery / CORS ---
EUREKA_URL=http://localhost:8761/eureka/
JARVIS_CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
# Gateway base URL the React app calls.
VITE_API_BASE=http://localhost:8080

# --- Integrations (added in later milestones) ---
# TELEGRAM_BOT_TOKEN=
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
