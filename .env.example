# Copy to .env and adjust. .env is gitignored.

# --- Database ---
DB_NAME=jarvis
DB_USER=jarvis
DB_PASSWORD=jarvis
JDBC_URL=jdbc:postgresql://localhost:5432/jarvis

# --- AI inference (local Ollama, ₹0) ---
JARVIS_PROFILE=local
OLLAMA_BASE_URL=http://localhost:11434
JARVIS_PARSER_MODEL=qwen3.5:9b
JARVIS_AGENT_MODEL=qwen3.5:27b

# --- Security (generate a real 32+ byte secret) ---
JARVIS_JWT_SECRET=change-me-in-env-at-least-32-bytes-long!!

# --- Integrations (added in later milestones) ---
# TELEGRAM_BOT_TOKEN=
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
